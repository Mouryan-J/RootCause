# Copy this file to .env and fill in your real values
# NEVER commit the .env file

OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
COHERE_API_KEY=your_cohere_key_here

# asyncpg driver required for SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/rootcause
REDIS_URL=redis://localhost:6379
QDRANT_URL=https://xxx.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Langfuse observability (free tier at cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here

# Authentication (leave empty to disable in dev; set a strong random string in production)
API_SECRET_KEY=

# Application
APP_ENV=development
LOG_LEVEL=INFO
